WANDB_API_KEY=your_api_key_here
WANDB_PROJECT=egosurgery_multitask
DATA_ROOT=/path/to/data
DINOV2_WEIGHTS=/path/to/dinov2_vitl14_reg4_pretrain.pth
# CUDA_VISIBLE_DEVICES は雛形から削除（2026/05/25）。
# 過去に .env を source した際にこれが export され、scripts/run_s0.sh の
# `torch.cuda.device_count()` が 1 を返し単一 GPU 逐次実行に分岐する事故が
# 発生した。GPU 個別実行が必要なら、shell で `CUDA_VISIBLE_DEVICES=0 python ...`
# のように都度指定すること（run_s0.sh は内部で各 run に明示設定する）。
# 実行サーバー名（M2研究計画 §14 実験結果ログ用）
# 推奨: shell rc 側で `export SERVERNAME=bengio` を設定する運用とし、
# .env は補助的な fallback。SERVERNAME が空のときのみ EGOSURGERY_SERVER_NAME を使う。
SERVERNAME=bengio

# ----------------------------------------------------------------------------
# Notion 「実験Run台帳」自動投稿 (src/egosurgery/utils/notion_logger.py)
# ----------------------------------------------------------------------------
# 未設定なら no-op (学習プロセスはエラーなく完走)。両方設定すると
# MMDetTrainer.run() が完走した瞬間に行を自動作成 (or 既存行を update)。
# トークン作成手順:
#   1) https://www.notion.so/profile/integrations で Internal Integration 作成
#   2) 実験Run台帳 DB を開く → ... → Add connections → 作成した Integration を選ぶ
# NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DB_ID=7bcf9406-29fc-4b2a-8a9e-0be02fc1fc20
# NOTION_SERVER_OPTION=philip (RTX 6000 Ada)
