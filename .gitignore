# === データ（中身は ignore・フォルダ構造のみ .gitkeep で保持）===
# 各ディレクトリで:
#   <dir>/**             ← 中身を全て ignore
#   !<dir>/**/           ← ただし子ディレクトリ自体は traverse させる（.gitkeep を見つけるため）
#   !<dir>/**/.gitkeep   ← .gitkeep だけは追跡
data/raw/**
!data/raw/**/
!data/raw/**/.gitkeep

data/annotations/**/*.json
data/annotations/egosurgery_hts/**
!data/annotations/egosurgery_hts/**/
!data/annotations/egosurgery_hts/**/.gitkeep
data/annotations/pseudo_labels/**
!data/annotations/pseudo_labels/**/
!data/annotations/pseudo_labels/**/.gitkeep

data/processed/**
!data/processed/**/
!data/processed/**/.gitkeep

data/external/**
!data/external/**/
!data/external/**/.gitkeep

# === 実験結果（大容量） ===
experiments/**/checkpoints/
experiments/**/logs/
experiments/**/predictions/
experiments/**/visualizations/
experiments/**/*.npy
experiments/**/*.pt
experiments/**/*.pth

# === モデル重み ===
*.pth
*.pt
*.ckpt
*.onnx
*.safetensors

# === W&B ===
wandb/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# === 仮想環境 ===
.venv/
venv/

# === IDE ===
.vscode/
.idea/
*.swp
*~
.DS_Store

# === Jupyter ===
.ipynb_checkpoints/

# === 環境変数 ===
.env

# === LaTeX ===
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.synctex.gz
paper/sections/*.aux

# === Git 管理する例外 ===
!data/README.md
!data/splits/
!data/splits/*
!experiments/README.md
!experiments/**/config.yaml
!experiments/**/command.sh
!experiments/**/git_commit.txt
!experiments/**/metrics.json
!experiments/**/per_class_ap.json
!experiments/**/notes.md
# 学習に使う tool 検出アノテーション（instances_*.json）は再現性のため追跡する。
# tool/ hand/ の生 COCO コピーは EgoSurgery 公式と重複・大容量のため追跡しない。
!data/annotations/egosurgery_tool/instances_*.json

# === third_party (外部 fork: MaskDINO 等) ===
third_party/

# === outputs (Hydra 実行ログ) ===
outputs/

# === Claude Code（個人設定のみ除外。commands/agents/skills は共有）===
.claude/settings.local.json
# 別セッションが作成した git worktree 跡（履歴外、ローカルのみ）
.claude/worktrees/

# === 退避フォルダ (S0 やり直しの過程で生まれたローカル証跡) ===
# 容量が大きい (合計 ~5.6GB) ため git 履歴には載せず、ローカルに保持して
# 再現性検証・監査用の参照点とする。
experiments/baselines/_aborted_s0_cuda_visible_misconfig/
experiments/baselines/_failed_num_workers_zero/
experiments/baselines/_smoke_prior_simplehead/
experiments/baselines/_smoke_v2_part3/
experiments/phase0/_pre_redo_s0_smoke/
experiments/phase0/_prior_no_eval_recipe/

# === 退避済みプロンプト (新シリーズで置換済み、ローカル参照用) ===
prompts_legacy/
prompts_n_legacy/
